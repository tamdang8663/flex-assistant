# ══════════════════════════════════════════════════════════════════════════════
# FLEX ASSISTANT — Environment Variables
#
# Setup instructions:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in all REQUIRED values below
#   3. Never commit .env.local to Git (it's in .gitignore)
#
# Full setup guides:
#   Supabase → docs/SUPABASE_SETUP.md
#   Vercel   → docs/VERCEL_DEPLOYMENT.md
# ══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC  (Required)
# Get your key at: https://console.anthropic.com
# Used for: screenshot OCR — route itineraries and gate code images
# Security: server-side ONLY — never sent to the browser
# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY removed — OCR now uses OCR.space


# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE  (All three required)
# Get these at: https://app.supabase.com → your project → Settings → API
# Run schema first: supabase/schema.sql in the Supabase SQL Editor
# ─────────────────────────────────────────────────────────────────────────────

# Project URL — safe to expose publicly
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon / public key — safe to expose (Row Level Security is the guard)
# Allows: SELECT, INSERT
# Blocks: UPDATE (except via server route), DELETE
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhtdHBucXRzdWxkcGUiLCJyb2xlIjoiYW5vbiIsImlhdCI6MTYxMzUzMTk4NSwiZXhwIjoxOTI5MTA3OTg1fQ...

# Service role key — SECRET, server-side ONLY, never expose
# Bypasses Row Level Security — used only by API routes
# Allows: all operations including UPDATE status and DELETE (admin)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhtdHBucXRzdWxkcGUiLCJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjEzNTMxOTg1LCJleHAiOjE5MjkxMDc5ODV9...


# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE MAPS  (Optional)
# Used for: precise route distance and driving time
# Without this, app uses a built-in estimate (~1.35 mi/stop, 20 mph avg)
#
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. Create a project → Enable "Distance Matrix API"
#   3. Create an API key → Restrict to your domain in production
#
# Cost: ~$5 per 1,000 route calculations (very low for daily use)
# Security: server-side ONLY — never sent to the browser
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# OPENROUTESERVICE  (Optional)
# Free alternative to Google Maps for route distances
# Used when GOOGLE_MAPS_API_KEY is not set
#
# Setup:
#   1. Go to https://openrouteservice.org/dev/#/signup
#   2. Register for a free account (no credit card required)
#   3. Generate an API token
#
# Free tier: 2,000 requests/day, 40 requests/minute
# Security: server-side ONLY
# ─────────────────────────────────────────────────────────────────────────────
ORS_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────────────────────
#
# Routing priority:
#   1. Google Maps (most accurate, small cost)
#   2. OpenRouteService (free, good accuracy)
#   3. Built-in heuristic (no key needed, ~15% accuracy)
#
# Variables prefixed NEXT_PUBLIC_ are embedded in the browser bundle.
# Only use this prefix for values safe to be publicly visible.
# All other variables stay server-side in Next.js API routes.
#
# For Vercel deployment, add these in:
#   Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# OCR.SPACE  (Required)
# Get your free key at: https://ocr.space/ocrapi/freekey
# Free tier: 25,000 requests/month
# Paid plans available at: https://ocr.space/pricing
# Security: server-side ONLY — never sent to the browser
# ─────────────────────────────────────────────────────────────────────────────
OCR_SPACE_API_KEY=helloworld
